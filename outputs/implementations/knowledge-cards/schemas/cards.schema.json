{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://knowledge-cards.local/schemas/cards.schema.json",
  "title": "Knowledge Cards Content File",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "pack_id", "source_refs", "cards"],
  "properties": {
    "schema_version": { "const": "knowledge-cards.cards.v1" },
    "pack_id": { "type": "string" },
    "source_refs": {
      "type": "array",
      "items": { "$ref": "./source-ref.schema.json" }
    },
    "cards": {
      "type": "array",
      "minItems": 50,
      "maxItems": 50,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "core_idea", "example", "key_takeaway", "connections", "difficulty", "importance", "foundational_priority", "category", "prerequisites", "source_refs", "media", "review_prompts", "boundary_note"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "core_idea": { "type": "array", "minItems": 2, "maxItems": 5, "items": { "type": "string" } },
          "example": { "type": "string" },
          "key_takeaway": { "type": "string" },
          "connections": { "type": "array" },
          "difficulty": { "type": "number", "minimum": 1, "maximum": 5 },
          "importance": { "type": "number", "minimum": 0, "maximum": 1 },
          "foundational_priority": { "type": "number", "minimum": 0, "maximum": 1 },
          "category": { "enum": ["foundations", "mechanisms", "applications", "misconceptions", "limitations", "bridges", "advanced-horizons"] },
          "prerequisites": { "type": "array", "items": { "type": "string" } },
          "source_refs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "media": { "type": ["object", "null"] },
          "review_prompts": { "type": "array", "minItems": 1, "items": { "$ref": "./review-prompt.schema.json" } },
          "boundary_note": { "type": "string" }
        }
      }
    }
  }
}
